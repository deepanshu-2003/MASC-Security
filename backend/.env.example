# =============================================================================
# MASC SECURITY - BACKEND ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control (it is in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# -----------------------------------------------------------------------------
# DATABASE - MongoDB
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/masc-security
# Production: MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/masc-security

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
# Use a strong random string (min 32 chars). Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Session duration in milliseconds (default: 7 days)
SESSION_DURATION_MS=604800000

# -----------------------------------------------------------------------------
# GOOGLE reCAPTCHA v3
# -----------------------------------------------------------------------------
# Register at: https://www.google.com/recaptcha/admin
# Choose reCAPTCHA v3 (score-based)
RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key_here
RECAPTCHA_MIN_SCORE=0.5

# -----------------------------------------------------------------------------
# TWILIO - SMS OTP Service
# -----------------------------------------------------------------------------
# Register at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# -----------------------------------------------------------------------------
# SMTP - Email Notification Service
# -----------------------------------------------------------------------------
# Gmail example: host=smtp.gmail.com port=587 (use App Password)
# Mailtrap (testing): host=sandbox.smtp.mailtrap.io port=2525
# SendGrid: host=smtp.sendgrid.net port=587 (API key as password)
SMTP_HOST=your_smtp_host_here
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_password_here
SMTP_FROM="MASC Security" <noreply@your-domain.com>

# -----------------------------------------------------------------------------
# CORS & FRONTEND URL
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
OTP_RATE_LIMIT_WINDOW_MS=900000
OTP_RATE_LIMIT_MAX=5

# -----------------------------------------------------------------------------
# VAULT ENCRYPTION (Future - Phase 5)
# -----------------------------------------------------------------------------
# Must be exactly 32 characters for AES-256-CBC
VAULT_ENCRYPTION_KEY=your_32_character_vault_key_here

# -----------------------------------------------------------------------------
# AI ENGINE (Future - Phase 8)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here


# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
FEATURE_SMS_OTP=true
FEATURE_EMAIL_VERIFICATION=true
FEATURE_RECAPTCHA=true
FEATURE_VAULT=false
FEATURE_AI_ENGINE=false
