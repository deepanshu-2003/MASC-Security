# =============================================================================
# MASC SECURITY - FRONTEND ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your values.
# Only VITE_* variables are exposed to the browser bundle.
# NEVER put secret keys (JWT secret, SMTP password, etc.) here!
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND API URL
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:5000/api/v1

# -----------------------------------------------------------------------------
# GOOGLE reCAPTCHA v3 - SITE KEY (public key only, safe for browser)
# -----------------------------------------------------------------------------
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key_here

# -----------------------------------------------------------------------------
# APP BRANDING
# -----------------------------------------------------------------------------
VITE_APP_NAME=MASC Security
VITE_APP_VERSION=1.0.0
