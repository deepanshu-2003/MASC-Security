# =============================================================================
# MASC SECURITY - Root .gitignore
# =============================================================================

# Environment variables - CRITICAL: Never commit these!
.env
.env.local
.env.*.local
backend/.env
frontend/.env
ai_engine/.env

# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
build/
**/build/

# Python virtual environments
ai_engine/venv/
ai_engine/__pycache__/
ai_engine/*.pyc
ai_engine/*.pyo
**/__pycache__/
**/*.pyc
**/*.pyo

# Logs
*.log
logs/
**/logs/

# OS files
.DS_Store
Thumbs.db
**/.DS_Store

# Editor
.vscode/
.idea/
*.suo
*.sw?

# MongoDB local data
data/
*.db

# Temp / scratch files
*.tmp
*.temp
scratch_simulate_bot.js

# Security audit report (internal use only)
list.txt

# Python ML model artefacts (large binary files)
ai_engine/models/*.pkl
ai_engine/models/*.joblib
ai_engine/models/*.h5
ai_engine/*.pkl
ai_engine/*.joblib

# Uploaded media / large assets
backend/uploads/
frontend/public/uploads/
